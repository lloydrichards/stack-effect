{
  "name": "base_bevr-stack",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && git clean -xdf node_modules .cache .turbo dist tsconfig.tsbuildinfo playwright-report test-results",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "prepare": "effect-language-service patch",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "start": "bun apps/cli/src/index.ts",
    "type-check": "turbo run type-check",
    "complexity": "bun run scripts/complexity-report.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@effect/language-service": "^0.85.1",
    "@effect/platform-bun": "4.0.0-beta.59",
    "@types/bun": "^1.3.13",
    "effect": "4.0.0-beta.59",
    "turbo": "^2.9.6",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
