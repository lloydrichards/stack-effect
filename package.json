{
  "name": "base_bevr-stack",
  "private": true,
  "scripts": {
    "ralph:afk": "bash .ralph/afk-ralph.sh",
    "ralph:once": "bash .ralph/ralph-once.sh",
    "ralph:github-update": "bun run .ralph/update-github-issues.ts",
    "ralph:sync-issues": "bun run .ralph/sync-issues.ts",
    "build": "turbo run build",
    "clean": "turbo run clean && git clean -xdf node_modules .cache .turbo dist tsconfig.tsbuildinfo playwright-report test-results",
    "dev": "turbo run dev",
    "lint": "biome lint .",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "prepare": "effect-language-service patch",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "type-check": "turbo run type-check",
    "complexity": "bun run scripts/complexity-report.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@effect/language-service": "^0.85.1",
    "@effect/platform-bun": "4.0.0-beta.47",
    "effect": "4.0.0-beta.47",
    "effect-boxes": "^0.10.0",
    "@playwright/test": "^1.59.1",
    "@types/bun": "^1.3.12",
    "tsmetrics-core": "^1.4.1",
    "turbo": "^2.9.6",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.21",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
